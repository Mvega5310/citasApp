# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Email Configuration (Optional)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_email@gmail.com
EMAIL_SERVER_PASSWORD=your_app_password

# Twilio Configuration (Optional - for WhatsApp)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Application Configuration
NEXT_PUBLIC_APP_NAME=BeautyTurno
NEXT_PUBLIC_APP_URL=http://localhost:3000 
APP_ENV=development
LOG_LEVEL=info
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_service_account_json
# or set individual fields instead of FIREBASE_SERVICE_ACCOUNT_BASE64
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
EMAIL_FROM=no-reply@beautyturno.com
EMAIL_TO_DEFAULT=marcosvega5310@gmail.com
